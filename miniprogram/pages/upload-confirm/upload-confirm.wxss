.upload-page.with-bottom-nav {
  padding-bottom: calc(340rpx + env(safe-area-inset-bottom));
}

.screen-title {
  margin-top: 34rpx;
  color: #101114;
  font-size: 48rpx;
  font-weight: 880;
}

.screen-desc {
  margin-top: 16rpx;
  color: #667085;
  font-size: 30rpx;
}

.file-card {
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  gap: 28rpx;
  min-height: 180rpx;
  margin-top: 36rpx;
  padding: 30rpx;
  border: 1rpx solid #e3e8f0;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 52rpx rgba(16, 24, 40, 0.06);
}

.file-card::before {
  content: "";
  position: absolute;
  left: 0;
  bottom: 0;
  width: 84rpx;
  height: 122rpx;
  background: #075be8;
  clip-path: polygon(0 0, 100% 100%, 0 100%);
}

.file-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  width: 122rpx;
  height: 122rpx;
  border-radius: 22rpx;
  background: #eef5ff;
  color: #075be8;
  font-size: 36rpx;
  font-weight: 850;
}

.file-info {
  min-width: 0;
  flex: 1;
}

.file-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #101114;
  font-size: 32rpx;
  font-weight: 820;
}

.file-meta {
  margin-top: 16rpx;
  color: #667085;
  font-size: 28rpx;
}

.selected-text {
  margin-top: 16rpx;
  color: #22a447;
  font-size: 28rpx;
}

.choose-again {
  color: #075be8;
  font-size: 28rpx;
  font-weight: 760;
}

.form-card {
  margin-top: 28rpx;
  padding: 0 28rpx 28rpx;
  border: 1rpx solid #e3e8f0;
  border-radius: 28rpx;
  background: #ffffff;
}

.form-row {
  display: flex;
  align-items: center;
  min-height: 120rpx;
  border-bottom: 1rpx solid #e3e8f0;
}

.row-label {
  flex: 0 0 auto;
  width: 210rpx;
  color: #101114;
  font-size: 30rpx;
}

.row-input {
  min-height: 0;
  padding: 0;
  border: 0;
  text-align: right;
  color: #475467;
}

.row-value {
  flex: 1;
  color: #475467;
  text-align: right;
  font-size: 29rpx;
}

.row-arrow {
  margin-left: 16rpx;
  color: #a0a9b8;
  font-size: 42rpx;
}

.note-block {
  padding-top: 28rpx;
}

.note-label {
  margin-bottom: 18rpx;
  color: #101114;
  font-size: 30rpx;
}

.note-block textarea {
  min-height: 170rpx;
  background: #fbfdff;
}

.count {
  margin-top: -42rpx;
  padding-right: 20rpx;
  color: #98a2b3;
  text-align: right;
  font-size: 26rpx;
}

.privacy-card {
  margin-top: 30rpx;
  padding: 26rpx 30rpx;
  border: 1rpx solid #ffd59a;
  border-radius: 22rpx;
  background: #fff7e8;
  color: #b65d00;
  font-size: 28rpx;
}

.rule-card {
  margin-top: 24rpx;
  padding: 26rpx 30rpx;
  border: 1rpx solid #cfe0ff;
  border-radius: 22rpx;
  background: #eef5ff;
  color: #233b6e;
  font-size: 28rpx;
  line-height: 1.55;
}

.submit-button {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  bottom: calc(150rpx + env(safe-area-inset-bottom));
  z-index: 90;
}
