<view class="page collect-page with-bottom-nav">
  <view class="collect-head">
    <view>
      <view class="collect-title">知识助手</view>
      <picker range="{{knowledgeBaseNames}}" value="{{selectedIndex}}" bindchange="onKnowledgeBaseChange">
        <view class="kb-select">{{selectedKnowledgeBaseName || "选择知识库"}}⌄</view>
      </picker>
    </view>
  </view>

  <view wx:if="{{needsSettings}}" class="notice-card">
    <view>请先配置 WeKnora API Base URL 和 API Key。</view>
    <button class="ghost-button notice-button" bindtap="openSettings">打开设置</button>
  </view>

  <view class="hero-card">
    <view class="hero-label">知识采集中心</view>
    <view class="hero-title">把好资料，收进科室知识库</view>
    <view class="hero-desc">提交后直接进入知识库处理流程</view>
    <view class="hero-bolt"></view>
  </view>

  <view class="action-grid">
    <view class="action-card" bindtap="openClipArticle">
      <view class="action-icon">🔗</view>
      <view class="action-title">剪藏文章</view>
      <view class="action-desc">粘贴公众号文章链接</view>
      <view class="action-arrow">›</view>
    </view>
    <view class="action-card" bindtap="openUpload">
      <view class="action-icon">⇧</view>
      <view class="action-title">上传文件</view>
      <view class="action-desc">从微信选择 PDF / Word</view>
      <view class="action-arrow">›</view>
    </view>
  </view>

  <bottom-nav active="collect" />
</view>
