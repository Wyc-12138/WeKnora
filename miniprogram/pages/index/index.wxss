.collect-page {
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
}

.collect-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding-top: 76rpx;
  margin-bottom: 34rpx;
}

.collect-title {
  color: #101114;
  font-size: 44rpx;
  font-weight: 850;
  line-height: 1.15;
}

.kb-select {
  width: auto;
  min-height: 0;
  padding: 12rpx 0 0;
  border: 0;
  background: transparent;
  color: #667085;
  font-size: 30rpx;
}

.mini-menu {
  width: 172rpx;
  height: 72rpx;
  min-height: 72rpx;
  margin: 0;
  padding: 0;
  border: 1rpx solid #dce3ee;
  border-radius: 999rpx;
  background: #ffffff;
  color: #101114;
  font-size: 34rpx;
}

.notice-card {
  margin-bottom: 24rpx;
  padding: 24rpx;
  border: 1rpx solid #cfe0ff;
  border-radius: 24rpx;
  background: #eef5ff;
  color: #344054;
  font-size: 27rpx;
}

.notice-button {
  min-height: 76rpx;
  margin-top: 18rpx;
}

.hero-card {
  position: relative;
  overflow: hidden;
  min-height: 246rpx;
  padding: 52rpx 42rpx;
  border-radius: 34rpx;
  background: #075be8;
  color: #ffffff;
  box-shadow: 0 24rpx 52rpx rgba(7, 91, 232, 0.26);
}

.hero-label {
  font-size: 30rpx;
  opacity: 0.92;
}

.hero-title {
  position: relative;
  z-index: 1;
  margin-top: 26rpx;
  font-size: 44rpx;
  font-weight: 850;
  line-height: 1.18;
}

.hero-desc {
  position: relative;
  z-index: 1;
  margin-top: 24rpx;
  font-size: 28rpx;
  opacity: 0.92;
}

.hero-bolt {
  position: absolute;
  right: -4rpx;
  top: 0;
  width: 164rpx;
  height: 100%;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0) 20%, rgba(255, 255, 255, 0.32) 20%, rgba(255, 255, 255, 0.32) 48%, rgba(255, 255, 255, 0.88) 48%, rgba(255, 255, 255, 0.88) 64%, rgba(255, 255, 255, 0) 64%);
}

.action-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
  margin-top: 34rpx;
}

.action-card {
  position: relative;
  overflow: hidden;
  min-height: 284rpx;
  padding: 34rpx 28rpx;
  border: 1rpx solid #e3e8f0;
  border-radius: 32rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 50rpx rgba(16, 24, 40, 0.06);
}

.action-card::before {
  content: "";
  position: absolute;
  left: 0;
  bottom: 0;
  width: 72rpx;
  height: 120rpx;
  background: #075be8;
  clip-path: polygon(0 0, 100% 100%, 0 100%);
}

.action-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 92rpx;
  height: 92rpx;
  border-radius: 24rpx;
  background: #eef5ff;
  color: #075be8;
  font-size: 42rpx;
}

.action-title {
  margin-top: 38rpx;
  color: #101114;
  font-size: 34rpx;
  font-weight: 820;
}

.action-desc {
  margin-top: 14rpx;
  color: #667085;
  font-size: 26rpx;
  line-height: 1.35;
}

.action-arrow {
  position: absolute;
  right: 28rpx;
  bottom: 28rpx;
  color: #075be8;
  font-size: 52rpx;
}

.section-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 48rpx 0 20rpx;
}

.section-title {
  color: #101114;
  font-size: 34rpx;
  font-weight: 820;
}

.link-button {
  min-height: 0;
  margin: 0;
  padding: 0;
  background: transparent;
  color: #075be8;
  font-size: 28rpx;
}

.empty-state {
  padding: 34rpx;
  border-radius: 24rpx;
  background: #ffffff;
  color: #667085;
  text-align: center;
}

.submission-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  min-height: 128rpx;
  margin-bottom: 20rpx;
  padding: 24rpx;
  border: 1rpx solid #e3e8f0;
  border-radius: 26rpx;
  background: #ffffff;
}

.submission-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  width: 86rpx;
  height: 86rpx;
  border-radius: 22rpx;
  background: #eef5ff;
  color: #075be8;
  font-size: 32rpx;
  font-weight: 800;
}

.submission-main {
  min-width: 0;
  flex: 1;
}

.submission-title {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #101114;
  font-size: 30rpx;
  font-weight: 760;
}

.submission-meta {
  margin-top: 8rpx;
  color: #667085;
  font-size: 25rpx;
}

.row-arrow {
  color: #a0a9b8;
  font-size: 42rpx;
}
