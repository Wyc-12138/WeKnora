.notice {
  margin-bottom: 30rpx;
  padding: 24rpx;
  border-radius: 26rpx;
  background: #fff7e8;
  color: #6b4b2f;
  font-size: 26rpx;
  line-height: 1.5;
}

.notice-button {
  width: 200rpx;
  margin-top: 18rpx;
  color: #2b2723;
}

.section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 20rpx;
}

.small-button {
  flex: 0 0 auto;
  min-width: 116rpx;
  margin: 0;
  border-radius: 999rpx;
  background: #ffffff;
  color: #292622;
  border: 1rpx solid rgba(34, 31, 28, 0.09);
}

.picker-value {
  background: #ffffff;
  color: #2b2824;
}

.material-list {
  margin-top: 26rpx;
}

.material-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(34, 31, 28, 0.08);
}

.material-type,
.material-meta {
  color: #847c72;
  font-size: 23rpx;
}

.material-title {
  margin-top: 8rpx;
  overflow: hidden;
  color: #211f1c;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 30rpx;
  font-weight: 680;
}

.material-meta {
  margin-top: 8rpx;
  word-break: break-all;
}

.url-panel {
  margin-top: 28rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.78);
  border: 1rpx solid rgba(34, 31, 28, 0.07);
}

.url-input {
  margin-top: 18rpx;
}

.error {
  margin-top: 24rpx;
  color: #ba3f2d;
  font-size: 24rpx;
  line-height: 1.5;
  white-space: pre-wrap;
}

.import-button {
  margin-top: 34rpx;
  background: #26231f;
}
