.shell-topbar {
  position: sticky;
  top: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  min-height: 126rpx;
  padding-left: 28rpx;
  padding-right: 28rpx;
  padding-bottom: 18rpx;
  background: rgba(251, 249, 244, 0.94);
  backdrop-filter: blur(18rpx);
}

.round-button,
.round-spacer {
  width: 72rpx;
  height: 72rpx;
  margin: 0;
  padding: 0;
  border-radius: 50%;
}

.round-button {
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(34, 31, 28, 0.08);
  background: #fbfaf7;
  color: #22201d;
  font-size: 36rpx;
  line-height: 72rpx;
  box-shadow: 0 8rpx 22rpx rgba(31, 28, 25, 0.06);
}

.round-button::after,
.new-chat::after,
.footer-icon-button::after {
  border: 0;
}

.menu-icon {
  flex-direction: column;
  gap: 9rpx;
}

.hamburger-line {
  width: 30rpx;
  height: 3rpx;
  border-radius: 999rpx;
  background: #2a2723;
}

.button-hover {
  opacity: 0.72;
}

.topbar-title {
  min-width: 0;
  flex: 1;
  text-align: center;
}

.model-title {
  color: #201d1a;
  font-family: Georgia, "Times New Roman", serif;
  font-size: 38rpx;
  font-weight: 600;
  line-height: 1.1;
}

.model-subtitle {
  margin-top: 4rpx;
  color: #7c756d;
  font-size: 22rpx;
}

.drawer-layer {
  position: fixed;
  inset: 0;
  z-index: 1000;
  opacity: 0;
  pointer-events: none;
  transition: opacity 260ms ease;
}

.drawer-layer.mounted {
  pointer-events: auto;
}

.drawer-layer.open {
  opacity: 1;
}

.drawer-mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.28);
}

.drawer-panel {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  width: 82vw;
  max-width: 650rpx;
  padding: 72rpx 28rpx calc(28rpx + env(safe-area-inset-bottom));
  background: #fbfaf7;
  box-shadow: 24rpx 0 70rpx rgba(34, 31, 28, 0.18);
  transform: translateX(-104%);
  transition: transform 260ms ease;
}

.drawer-layer.open .drawer-panel {
  transform: translateX(0);
}

.drawer-main {
  min-height: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
}

.drawer-brand {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 24rpx;
}

.brand-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  border-radius: 22rpx;
  background: #d97745;
  color: #ffffff;
  font-family: Georgia, "Times New Roman", serif;
  font-size: 36rpx;
  font-weight: 700;
}

.brand-name {
  color: #211f1c;
  font-size: 34rpx;
  font-weight: 750;
}

.new-chat {
  width: 100%;
  height: 82rpx;
  margin: 0 0 22rpx;
  border-radius: 24rpx;
  background: #26231f;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 650;
  line-height: 82rpx;
}

.search-box {
  display: flex;
  align-items: center;
  gap: 12rpx;
  box-sizing: border-box;
  height: 78rpx;
  margin-bottom: 18rpx;
  padding: 0 20rpx;
  border-radius: 24rpx;
  background: #f0eee9;
}

.search-icon {
  color: #8a837a;
  font-size: 34rpx;
}

.search-input {
  flex: 1;
  min-height: 72rpx;
  padding: 0;
  border: 0;
  background: transparent;
  color: #211f1c;
  font-size: 28rpx;
}

.session-scroll {
  min-height: 0;
  flex: 1;
}

.drawer-empty {
  padding: 44rpx 0;
  color: #8b837a;
  text-align: center;
  font-size: 25rpx;
}

.session-row {
  display: flex;
  align-items: center;
  min-height: 78rpx;
  padding: 10rpx 0;
}

.session-text {
  min-width: 0;
  flex: 1;
  overflow: hidden;
  color: #211f1c;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 28rpx;
  font-weight: 650;
}

.drawer-footer {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(34, 31, 28, 0.08);
}

.footer-account {
  min-width: 0;
  flex: 1;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.account-avatar {
  flex: 0 0 auto;
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  background: #eee8de;
}

.account-avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #7b5f42;
  font-size: 26rpx;
  font-weight: 750;
}

.account-name {
  min-width: 0;
  flex: 1;
  overflow: hidden;
  color: #292622;
  font-size: 28rpx;
  font-weight: 650;
  line-height: 1.2;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.footer-actions {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.footer-icon-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  margin: 0;
  padding: 0;
  border-radius: 50%;
  background: transparent;
  color: #292622;
  line-height: 64rpx;
}

.footer-icon-button.active {
  background: #f0eee9;
}

.footer-action-icon {
  font-size: 34rpx;
  line-height: 1;
}
